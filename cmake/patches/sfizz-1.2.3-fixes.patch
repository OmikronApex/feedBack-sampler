diff --git a/cmake/SfizzConfig.cmake b/cmake/SfizzConfig.cmake
index ff0ab5eb..147049e6 100644
--- a/cmake/SfizzConfig.cmake
+++ b/cmake/SfizzConfig.cmake
@@ -51,7 +51,10 @@ endif()
 
 # Set macOS compatibility level
 if(APPLE)
-    set(CMAKE_OSX_DEPLOYMENT_TARGET "10.9")
+    # fbsampler: 10.15+ so ghc/fs_std.hpp maps its `fs` alias to
+    # std::filesystem (the header falls back to ghc::filesystem below 10.15),
+    # matching the C++17 consumers that link sfizz::parser.
+    set(CMAKE_OSX_DEPLOYMENT_TARGET "10.15")
 endif()
 
 # If using C++17, check if aligned-new has runtime support on the platform;
@@ -99,7 +102,7 @@ if(CMAKE_CXX_COMPILER_ID MATCHES "GNU|Clang")
     gw_warn(-Wall -Wextra -Wno-multichar -Werror=return-type)
     if(PROJECT_SYSTEM_PROCESSOR MATCHES "(i.86|x86_64)")
         add_compile_options(-msse2)
-    elseif(PROJECT_SYSTEM_PROCESSOR MATCHES "(arm.*)")
+    elseif(PROJECT_SYSTEM_PROCESSOR MATCHES "(arm.*)" AND NOT PROJECT_SYSTEM_PROCESSOR MATCHES "(arm64|aarch64)")
         add_compile_options(-mfpu=neon)
         if(NOT ANDROID)
             add_compile_options(-mfloat-abi=hard)
diff --git a/src/sfizz/Buffer.h b/src/sfizz/Buffer.h
index 12345678..87654321 100644
--- a/src/sfizz/Buffer.h
+++ b/src/sfizz/Buffer.h
@@ -183,7 +183,10 @@
         if (endMisalignment != 0)
             _alignedEnd = normalEnd + Alignment - endMisalignment;
         else
             _alignedEnd = normalEnd;
-
-        std::memcpy(normalData, oldNormalData, std::min(newSize, oldSize) * sizeof(Type));
+
+        // fbsampler: guard the first-resize case (oldNormalData == nullptr,
+        // size 0) -- memcpy's args are declared nonnull and UBSan flags it.
+        if (oldNormalData != nullptr)
+            std::memcpy(normalData, oldNormalData, std::min(newSize, oldSize) * sizeof(Type));
         std::free(oldData);
